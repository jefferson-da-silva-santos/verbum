{
  "expo": {
    "name": "Verbum",
    "slug": "verbum",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "verbum",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F1E3"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.verbum.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Verbum não utiliza câmera.",
        "NSPhotoLibraryUsageDescription": "Para salvar imagens exportadas."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png",
        "backgroundColor": "#F7F1E3"
      },
      "package": "com.verbum.app",
      "versionCode": 1,
      "permissions": []
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": false
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "backgroundColor": "#F7F1E3",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dc0889a4-e27c-46f1-8f1d-e2170b537507"
      }
    },
    "owner": "jeffersondevvvv"
  }
}
